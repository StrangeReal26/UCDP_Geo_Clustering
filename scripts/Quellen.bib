@inproceedings{das_-depth_2025,
	title = {An in-{Depth} {Analysis} of {Eps} and {MinPts} {Selection} in {DBSCAN} with {Genetic} {Algorithm} {Optimization}},
	issn = {2603-3267},
	url = {https://ieeexplore.ieee.org/document/11098445},
	doi = {10.1109/ICEST66328.2025.11098445},
	abstract = {DBSCAN (Density-Based Spatial Clustering of Applications with Noise) has been recognized as a powerful clustering algorithm for detecting non-linearly separable clusters but has faced challenges in selecting optimal MinPts (the minimum number of points required to form a cluster) and Eps (the radius defining the neighborhood of a point) values, which have typically been chosen experimentally. To overcome this, we have introduced a Genetic algorithm (GA) driven optimization approach that has dynamically adjusts these parameters using a well-defined fitness function. Comparative evaluations with K-means and hierarchical clustering across diverse datasets have confirmed that our method has enhanced clustering effectiveness, making it a reliable choice for complex data analysis.},
	urldate = {2026-03-13},
	booktitle = {2025 60th {International} {Scientific} {Conference} on {Information}, {Communication} and {Energy} {Systems} and {Technologies} ({ICEST})},
	author = {Das, Anamika and Mandal, Monalisa},
	month = jun,
	year = {2025},
	note = {ISSN: 2603-3267},
	keywords = {DBSCAN, Eps, Genetic Algorithm, Genetic algorithms, Manuals, Measurement, Medical services, MinPts, Noise, Optimization, Real-time systems, Refining, Reliability, Tuning},
	pages = {1--4},
}

@article{bushra_comparative_2021,
	title = {Comparative {Analysis} {Review} of {Pioneering} {DBSCAN} and {Successive} {Density}-{Based} {Clustering} {Algorithms}},
	volume = {9},
	issn = {2169-3536},
	url = {https://ieeexplore.ieee.org/abstract/document/9453785},
	doi = {10.1109/ACCESS.2021.3089036},
	abstract = {The density-based spatial clustering of applications with noise (DBSCAN) is regarded as a pioneering algorithm of the density-based clustering technique. It provides the ability to handle outlier objects, detect clusters of different shapes, and disregard the need for prior knowledge about existing clusters in a dataset. These features along with its simplistic approach helped it become widely applicable in many areas of science. However, for all its accolades, the DBSCAN still has limitations in terms of performance, its ability to detect clusters of varying densities, and its dependence on user input parameters. Multiple DBSCAN-inspired algorithms have been subsequently proposed to alleviate these and more problems of the algorithm. In this paper, the implementation, features, strengths, and drawbacks of the DBSCAN are thoroughly examined. The successive algorithms proposed to provide improvement on the original DBSCAN are classified based on their motivations and are discussed. Experimental tests were conducted to understand and compare the changes presented by a C++ implementation of these algorithms along with the original DBSCAN algorithm. Finally, the analytical evaluation is presented based on the results found.},
	urldate = {2026-03-13},
	journal = {IEEE Access},
	author = {Bushra, Adil Abdu and Yi, Gangman},
	year = {2021},
	keywords = {Task analysis, clustering, DBSCAN, Classification algorithms, Clustering algorithms, Data models, Object recognition, Partitioning algorithms, spatial database, Spatial databases, Unsupervised learning},
	pages = {87918--87935},
}

