@article{oberg_mapping_2025,
	title = {Mapping global violence: {The} {Uppsala} {Conflict} {Data} {Program}},
	volume = {8},
	issn = {2590-3322},
	shorttitle = {Mapping global violence},
	url = {https://www.sciencedirect.com/science/article/pii/S2590332225002209},
	doi = {10.1016/j.oneear.2025.101394},
	abstract = {This Primer presents the Uppsala Conflict Data Program (UCDP), a leading source of systematic information on armed conflict globally. UCDP data are used across numerous disciplines in the social sciences, natural sciences, and medicine to analyze conflict causes, climate change impacts, human health and environmental consequences, and much more. The UCDP collects geo-referenced event data on three types of organized violence: state-based conflicts, non-state conflicts, and one-sided violence. This Primer describes the content of UCDP’s core conflict data, the definitions, and the types of source materials used to collect the data. It also highlights key constraints and limitations of conflict event data collection, including challenges with information dissemination, censorship, and the handling of uncertainty in source materials. Furthermore, it describes the UCDP Conflict Encyclopedia, an online tool with interactive maps, graphs, and textual information about conflicts, actors, and conflict-affected countries. Finally, it provides some practical advice on how to use and access UCDP data.},
	number = {9},
	urldate = {2026-01-26},
	journal = {One Earth},
	author = {Öberg, Magnus},
	month = sep,
	year = {2025},
	keywords = {conflict data, data collection, events data, geo-location, UCDP},
}

